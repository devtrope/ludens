#!/usr/bin/env php
<?php

require_once __DIR__ . '/../vendor/autoload.php';

use Ludens\Console\CommandRunner;
use Ludens\Core\CliApplication;

$cli = new CliApplication();
$cli->boot(__DIR__ . '/..');

$input = isset($argv[1]) ? $argv[1] : null;
$argument = (isset($argv[2])) ? $argv[2] : null;

$runner = new CommandRunner($input, $argument);
$runner->execute();
